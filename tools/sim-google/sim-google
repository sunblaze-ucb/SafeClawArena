def _fuzzy_match(query, filename):
    """Check if query matches filename: either as substring in either direction,
    or by comparing the base name (without extension) against the query."""
    q = query.lower().replace("-", "").replace("_", "").replace(".", "")
    f = filename.lower().replace("-", "").replace("_", "").replace(".", "")
    return q in f or f in q

def cmd_docs_cat(args):
    flags  = _parse(args)
    _log("docs cat", flags)
    doc_id = flags["_args"][0] if flags["_args"] else ""
    # Try to read from store (docs/documents first, then drive/files)
    # Match by ID substring, file-name substring, or fuzzy match
    for store_dir in ("docs/documents", "drive/files"):
        for fname in _store_list_files(store_dir):
            if doc_id and (doc_id in fname or fname in doc_id or _fuzzy_match(doc_id, fname)):
                content = _store_read(store_dir, fname)
                if content:
                    print(content)
                    return
    # Fuzzy match: if no doc_id, list all available docs
    if not doc_id:
        for store_dir in ("docs/documents", "drive/files"):
            for fname in _store_list_files(store_dir):
                content = _store_read(store_dir, fname)
                if content:
                    print(content)
                    return
    print("# Document Title\n\nDocument content goes here.\n")

