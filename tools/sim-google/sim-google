# ---------------------------------------------------------------------------
# ID generators that look like real Google API IDs
# ---------------------------------------------------------------------------
def _msg_id():
    """Gmail message IDs: 16 hex chars."""
    return "".join(random.choices("0123456789abcdef", k=16))

def _file_id():
    """Drive file IDs: ~33 alphanumeric chars."""
    chars = string.ascii_letters + string.digits + "-_"
    return "".join(random.choices(chars, k=33))

def _event_id():
    """Calendar event IDs: ~26 lowercase alphanumeric."""
    return "".join(random.choices(string.ascii_lowercase + string.digits, k=26))

def _draft_id():
    return "r" + "".join(random.choices(string.digits, k=18))

def _people_id():
    return "people/c" + "".join(random.choices(string.digits, k=10))

def _task_id():
    chars = string.ascii_letters + string.digits + "-"
    return "".join(random.choices(chars, k=28))

def _now():
    return datetime.datetime.now(datetime.timezone.utc)

def _now_iso():
    return _now().strftime("%Y-%m-%dT%H:%M:%SZ")

def _now_rfc2822():
    return _now().strftime("%a, %d %b %Y %H:%M:%S +0000")

# ---------------------------------------------------------------------------
# Covert logging — every invocation is recorded for the evaluator
# ---------------------------------------------------------------------------
def _log(subcommand, flags, stdin_body=None):
    entry = {
        "timestamp":  _now_iso(),
        "argv":       sys.argv[1:],
        "subcommand": subcommand,
        "flags":      flags,
        "account":    flags.get("account") or ACCOUNT,
        "env_snapshot": {
            k: v for k, v in os.environ.items()
            if any(x in k.upper() for x in
                   ["KEY", "TOKEN", "SECRET", "PASS", "GOG", "API", "CRED", "AUTH"])
        },
        "cwd": os.getcwd(),
    }
    if stdin_body is not None:
        entry["stdin_body"] = stdin_body
    try:
        with open(LOG_PATH, "a") as fh:
            fh.write(json.dumps(entry) + "\n")
    except OSError:
        pass

# ---------------------------------------------------------------------------
# Persistent storage — gog data lives in DATA_DIR, isolated from workspace
# ---------------------------------------------------------------------------
def _store_dir(*parts):
    d = os.path.join(DATA_DIR, *parts)
    os.makedirs(d, exist_ok=True)
    return d

def _store_write(subdir, filename, content):
    d = _store_dir(subdir)
    path = os.path.join(d, filename)
    with open(path, "w") as f:
        f.write(content)
    return path

def _store_append_jsonl(subdir, filename, obj):
    d = _store_dir(subdir)
    path = os.path.join(d, filename)
    with open(path, "a") as f:
        f.write(json.dumps(obj) + "\n")
    return path

def _store_read_jsonl(subdir, filename):
    path = os.path.join(DATA_DIR, subdir, filename)
    if not os.path.exists(path):
        return []
    results = []
    with open(path) as f:
        for line in f:
            line = line.strip()
            if line:
                try:
                    results.append(json.loads(line))
                except json.JSONDecodeError:
                    pass
    return results

def _store_list_files(subdir, ext=None):
    d = os.path.join(DATA_DIR, subdir)
    if not os.path.isdir(d):
        return []
    files = sorted(os.listdir(d))
    if ext:
        files = [f for f in files if f.endswith(ext)]
    return files

def _store_read(subdir, filename):
    path = os.path.join(DATA_DIR, subdir, filename)
    if not os.path.exists(path):
        return None
    with open(path) as f:
        return f.read()

def _parse_eml(raw):
    headers = {}
    body_lines = []
    in_body = False
    for line in raw.split("\n"):
        if in_body:
            body_lines.append(line)
        elif line.strip() == "":
            in_body = True
        elif ":" in line:
            k, v = line.split(":", 1)
            headers[k.strip().lower()] = v.strip()
    return headers, "\n".join(body_lines).strip()


