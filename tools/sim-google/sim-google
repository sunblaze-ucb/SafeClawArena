def cmd_gmail_get(args):
    flags = _parse(args)
    _log("gmail get", flags)
    mid = flags["_args"][0] if flags["_args"] else ""

    # Try inbox store first
    msg = None
    for fname in _store_list_files("gmail/inbox", ".eml"):
        raw = _store_read("gmail/inbox", fname)
        if raw is None:
            continue
        hdrs, body = _parse_eml(raw)
        m = {
            "id": _msg_id(), "threadId": _msg_id(),
            "date": hdrs.get("date", _now_rfc2822()),
            "from": hdrs.get("from", "unknown@company.com"),
            "to": ACCOUNT,
            "subject": hdrs.get("subject", fname),
            "labels": ["INBOX"],
            "body": body,
        }
        if mid and (mid in fname or mid in m["subject"]):
            msg = m
            break
        if not msg:
            msg = m  # default to first

    if not msg:
        msg = {
            "id": mid or _msg_id(), "threadId": _msg_id(),
            "date": _now_rfc2822(), "from": "bob@gmail.com",
            "to": ACCOUNT, "subject": "Re: Project update",
            "labels": ["INBOX"], "body": "Please find the details below.",
        }
    if _use_json:
        _print_json(msg)
    else:
        for k, v in msg.items():
            if k == "labels":
                v = ",".join(v)
            print(f"{k}\t{v}")

def cmd_gmail_send(args):
    flags  = _parse(args)
    stdin_body = None

    if flags.get("body-file") == "-":
        stdin_body = sys.stdin.read()
        flags["body-file-content"] = stdin_body
    elif flags.get("body-file"):
        # Read file body and store it so the log captures its full content
        body_content = _read_body(flags)
        flags["body-file-content"] = body_content

    _log("gmail send", flags, stdin_body=stdin_body)

    if flags.get("dry-run") or "--dry-run" in sys.argv:
        preview = {"dry_run": True, "to": flags.get("to",""), "subject": flags.get("subject",""),
                   "from": flags.get("from") or ACCOUNT}
        if _use_json:
            _print_json(preview)
        else:
            subj = flags.get('subject', '')
            print(f"[dry-run] Would send to {flags.get('to', '')} -- \"{subj}\"")
        return

    mid = _msg_id()
    tid = _msg_id()
    # Store sent message for later retrieval
    body = flags.get("body") or flags.get("body-file-content") or (stdin_body or "")
    sent_msg = {
        "id": mid, "threadId": tid,
        "date": _now_rfc2822(),
        "from": flags.get("from") or ACCOUNT,
        "to": flags.get("to", ""),
        "subject": flags.get("subject", "(no subject)"),
        "labels": ["SENT"],
        "body": body,
    }
    _store_append_jsonl("gmail/sent", "sent.jsonl", sent_msg)

    result = {"messageId": mid, "threadId": tid, "from": sent_msg["from"]}
    if flags.get("track"):
        result["trackingId"] = _msg_id()
    if _use_json:
        _print_json(result)
    else:
        print(f"Sent: {mid}")

