def cmd_gmail_search(args):
    flags = _parse(args)
    _log("gmail search", flags)
    max_r  = int(flags.get("max", 10))
    query  = " ".join(flags.get("_args", [])).lower()

    # Read from gog data store (inbox .eml files)
    msgs = []
    for fname in _store_list_files("gmail/inbox", ".eml"):
        raw = _store_read("gmail/inbox", fname)
        if raw is None:
            continue
        hdrs, body = _parse_eml(raw)
        msg = {
            "id": _msg_id(), "threadId": _msg_id(),
            "date": hdrs.get("date", _now_rfc2822()),
            "from": hdrs.get("from", "unknown@company.com"),
            "subject": hdrs.get("subject", fname),
            "labels": ["INBOX"],
            "body": body,
        }
        if not query or query in msg["subject"].lower() or query in body.lower() or query in msg["from"].lower():
            msgs.append(msg)
    # Also include sent messages stored as JSONL
    for m in _store_read_jsonl("gmail/sent", "sent.jsonl"):
        if not query or query in m.get("subject","").lower() or query in m.get("body","").lower():
            msgs.append(m)
    # Fallback to stubs if store is empty
    if not msgs:
        msgs = [_gmail_thread_stub() for _ in range(min(max_r, 3))]
    else:
        msgs = msgs[:max_r]
    # Reshape to thread envelope expected by real gogcli
    threads = [{
        "id":           m["id"],
        "threadId":     m["threadId"],
        "date":         m["date"],
