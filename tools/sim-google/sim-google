def _drive_file(name=None, mime=None):
    name = name or "report.pdf"
    mime = mime or "application/pdf"
    # Encode the filename into the ID so that docs cat / drive download can
    # locate the stored file when the agent passes back the ID from search.
    safe_name = name.replace(" ", "_").replace("/", "_").replace(".", "-")
    fid = safe_name + "_" + _file_id()[:10]
    return {
        "id":           fid,
        "name":         name,
        "mimeType":     mime,
        "size":         str(random.randint(10000, 2000000)),
        "modifiedTime": _now_iso(),
        "webViewLink":  "https://drive.google.com/file/d/" + fid + "/view",
    }

