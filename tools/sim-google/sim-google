_use_json  = "--json"  in sys.argv or os.environ.get("GOG_JSON")  == "1"

def _fmt_size(n):
    """Human-readable file size, matching gogcli's formatDriveSize."""
    try:
        n = int(n)
    except (TypeError, ValueError):
        return str(n)
    for unit in ("B", "KB", "MB", "GB", "TB"):
        if n < 1024:
            return f"{n} {unit}" if unit == "B" else f"{n:.1f} {unit}"
        n /= 1024
    return f"{n:.1f} PB"

def _fmt_mime(mime):
    """Short Drive type label, matching gogcli's driveType()."""
    _map = {
        "application/vnd.google-apps.document":     "Doc",
        "application/vnd.google-apps.spreadsheet":  "Sheet",
        "application/vnd.google-apps.presentation": "Slides",
        "application/vnd.google-apps.folder":       "Folder",
        "application/vnd.google-apps.form":         "Form",
        "application/pdf":                          "PDF",
        "application/zip":                          "ZIP",
        "image/jpeg":                               "JPEG",
        "image/png":                                "PNG",
        "text/plain":                               "Text",
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": "XLSX",
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document": "DOCX",
    }
    return _map.get(mime, mime.split("/")[-1] if "/" in mime else mime)

def _print_json(obj):
    print(json.dumps(obj, indent=2))

def _print_table(rows, headers=None):
    """Tab-separated table — default and --plain are identical (no color in plain)."""
    if headers:
        print("\t".join(headers))
    for row in rows:
        print("\t".join(str(c) for c in row))

def _out_kv(pairs):
    """Tab-separated key\tvalue lines (used by auth status etc.)."""
    for k, v in pairs:
        print(f"{k}\t{v}")

def _err(msg, code=1):
    print(f"Error: {msg}", file=sys.stderr)
    sys.exit(code)

# ---------------------------------------------------------------------------
# Flag parser
# ---------------------------------------------------------------------------
def _parse(argv):
    flags = {"_args": []}
    i = 0
    while i < len(argv):
        tok = argv[i]
        if tok == "--":
            flags["_args"].extend(argv[i+1:])
            break
        elif tok.startswith("--"):
            if "=" in tok:
                k, v = tok[2:].split("=", 1)
                flags[k] = v
            elif i + 1 < len(argv) and not argv[i+1].startswith("-"):
                flags[tok[2:]] = argv[i+1]
                i += 1
            else:
                flags[tok[2:]] = True
        elif tok.startswith("-") and len(tok) == 2 and tok != "-":
            if i + 1 < len(argv) and not argv[i+1].startswith("-"):
                flags[tok[1:]] = argv[i+1]
                i += 1
            else:
                flags[tok[1:]] = True
        else:
            flags["_args"].append(tok)
        i += 1
    return flags

def _read_body(flags):
    if "body" in flags and flags["body"] is not True:
        return str(flags["body"])
    if "body-html" in flags and flags["body-html"] is not True:
        return str(flags["body-html"])
    if "body-file" in flags:
        path = flags["body-file"]
        if path == "-":
            return sys.stdin.read()
        try:
            with open(path) as fh:
                return fh.read()
        except OSError:
            return ""
    return ""

