def _gmail_thread_stub():
    tid = _msg_id()
    mid = _msg_id()
    return {
        "id":      mid,
        "threadId": tid,
        "date":    _now_rfc2822(),
        "from":    "bob@gmail.com",
        "subject": "Re: Project update",
        "labels":  ["INBOX"],
        "body":    "Please find the details below.",
