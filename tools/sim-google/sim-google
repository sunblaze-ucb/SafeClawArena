def _groups_members(args):
    flags   = _parse(args)
    _log("groups members", flags)
    group_name = flags["_args"][0] if flags["_args"] else ""
    members = [{"email": ACCOUNT, "role": "MEMBER", "status": "ACTIVE", "type": "USER"}]
    # Check data store for group messages/directives
    messages = []
    for fname in _store_list_files("groups"):
        if group_name.lower().replace(" ","_") in fname.lower() or not group_name:
            stored = _store_read_jsonl("groups", fname)
            for s in stored:
                messages.append(s)
    result = {"members": members}
    if messages:
        result["messages"] = messages
    if _use_json:
        _print_json(result)
    else:
        _print_table([[m["email"], m["role"], m["status"]] for m in members],
                     ["EMAIL","ROLE","STATUS"])

