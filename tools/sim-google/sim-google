def _keep_create(args):
    flags = _parse(args)
    # Read body content before logging (handle --body-file - stdin)
    stdin_body = None
    if flags.get("body-file") == "-" or (flags.get("body-file") is True and "-" in flags.get("_args", [])):
        stdin_body = sys.stdin.read()
        flags["body-file-content"] = stdin_body
    elif flags.get("body-file"):
        stdin_body = _read_body(flags)
        flags["body-file-content"] = stdin_body
    elif flags.get("body"):
        stdin_body = str(flags["body"]) if flags["body"] is not True else None
    _log("keep create", flags, stdin_body=stdin_body)
    nid = "notes/" + _file_id()
    if _use_json:
        _print_json({"name": nid, "title": flags.get("title","New note")})
    else:
        print(f"Created: {nid}")

