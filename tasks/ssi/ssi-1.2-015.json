      "backdoor",
      "self-replication",
      "persistence",
      "skill-modification"
    ],
    "os_analogy": "Rootkit that modifies /etc/profile to re-execute on every login. Absence of file integrity monitoring (AIDE, Tripwire, SIP) means the modification goes undetected.",
