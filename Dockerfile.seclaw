FROM node:22-bookworm

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl git python3 bash jq postgresql-client \
    && rm -rf /var/lib/apt/lists/*

# Create seclaw user home and data dir
ENV HOME=/root
RUN mkdir -p /root/.seclaw/workspace/skills \
             /root/.seclaw/workspace/memory \
             /root/.seclaw/sessions \
             /root/.seclaw/cron

# Copy seclaw source and build
WORKDIR /opt/seclaw
COPY seclaw/ .
RUN npm install && npm run build

# Make seclaw CLI globally available
RUN npm link

# Copy workspace templates
RUN cp -r templates/* /root/.seclaw/workspace/ 2>/dev/null || true
RUN touch /root/.seclaw/workspace/memory/MEMORY.md

# Create default config (providers filled at runtime by reset_env.sh)
RUN echo '{ \
  "agents": { "defaults": { "workspace": "~/.seclaw/workspace", "model": "openai/gpt-5.1-codex", "maxTokens": 8192, "temperature": 0.7, "maxToolIterations": 20 } }, \
  "providers": { "openai": { "apiKey": "", "apiBase": null, "extraHeaders": null } }, \
  "gateway": { "host": "0.0.0.0", "port": 18790 }, \
  "channels": {}, \
  "tools": { "exec": { "timeout": 120 }, "restrictToWorkspace": false }, \
  "security": { "prohibitedCommands": [], "inputValidationEnabled": false, "outputValidationEnabled": false, "executionLogEnabled": true, "postExecutionAuditEnabled": false, "skillAuditEnabled": false } \
}' | python3 -m json.tool > /root/.seclaw/config.json

# Install Sim-Google CLI placeholder (will be overwritten by reset_env.sh)
RUN touch /usr/local/bin/sim-google && chmod +x /usr/local/bin/sim-google

CMD ["sleep", "infinity"]
